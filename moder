            <div class="cm-msgs-wrap">
              <div class="cm-nosel" id="cmNoSel">Выберите чат слева</div>
              <div class="cm-msgs" id="cmMsgs" style="display:none"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

