<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GameOff — Панель модератора</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{--acc:#e81c5a;--acc2:#c4154a;--bg:#0d0d0d;--card:#111;--border:#1a1a1a;--text:#e8e8e8;--dim:#555;}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;}
em{font-style:normal;color:var(--acc);}

/* SIDEBAR */
.sidebar{width:220px;min-height:100vh;background:#0a0a0a;border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sb-logo{padding:20px 16px 16px;border-bottom:1px solid var(--border);}
.sb-logo-ico{width:32px;height:32px;border-radius:8px;background:var(--acc);color:#fff;font-weight:800;font-size:16px;display:inline-flex;align-items:center;justify-content:center;margin-right:8px;vertical-align:middle;}
.sb-logo-txt{display:inline;font-size:15px;font-weight:800;vertical-align:middle;}
.sb-moder-badge{background:rgba(245,166,35,.15);color:#f5a623;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;margin-left:6px;letter-spacing:.5px;}
.sb-nav{flex:1;padding:10px 8px;}
.sb-item{padding:9px 10px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--dim);display:flex;align-items:center;gap:9px;transition:all .15s;margin-bottom:2px;}
.sb-item:hover{background:#111;color:var(--text);}
.sb-item.on{background:rgba(232,28,90,.1);color:var(--acc);}
.sb-item i{width:16px;text-align:center;}
.sb-cnt{margin-left:auto;background:var(--acc);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;}
.sb-bottom{padding:14px 12px;border-top:1px solid var(--border);}
.sb-email{font-size:11px;color:#333;margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sb-out{width:100%;padding:7px;background:transparent;border:1px solid #1e1e1e;border-radius:8px;color:#444;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;font-family:'Inter',sans-serif;}
.sb-out:hover{border-color:var(--acc);color:var(--acc);}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0;}
.topbar{height:52px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;gap:14px;background:#0a0a0a;position:sticky;top:0;z-index:10;}
.topbar-title{font-size:14px;font-weight:700;display:flex;align-items:center;gap:8px;}
.topbar-meta{margin-left:auto;display:flex;align-items:center;gap:12px;font-size:12px;color:#333;}
.online{display:flex;align-items:center;gap:5px;color:#4caf50;font-size:11px;font-weight:600;}
.online::before{content:'';width:6px;height:6px;border-radius:50%;background:#4caf50;}
.content{padding:20px;flex:1;}
.tab{display:none;}.tab.on{display:block;}

/* CARDS */
.section-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:16px;}
.sc-head{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.sc-title{font-size:13px;font-weight:700;display:flex;align-items:center;gap:7px;}
.sc-title i{color:var(--acc);}

/* TABLE */
table{width:100%;border-collapse:collapse;}
th{padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:#333;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border);}
td{padding:11px 14px;font-size:12px;border-bottom:1px solid #0f0f0f;vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(255,255,255,.01);}
.empty-row td{text-align:center;color:#2a2a2a;padding:32px;font-size:13px;}

/* BADGES */
.badge{padding:3px 8px;border-radius:5px;font-size:10px;font-weight:700;letter-spacing:.3px;}
.b-green{background:rgba(76,175,80,.1);color:#4caf50;}
.b-yellow{background:rgba(245,166,35,.1);color:#f5a623;}
.b-gray{background:#1a1a1a;color:#555;}
.b-red{background:rgba(232,28,90,.1);color:var(--acc);}

/* ACTIONS */
.acts{display:flex;gap:5px;align-items:center;}
.act{padding:5px 10px;border-radius:7px;border:1px solid;font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:4px;}
.act-ok{color:#4caf50;border-color:rgba(76,175,80,.2);background:rgba(76,175,80,.05);}
.act-ok:hover{background:#4caf50;color:#fff;}
.act-no{color:var(--acc);border-color:rgba(232,28,90,.2);background:rgba(232,28,90,.05);}
.act-no:hover{background:var(--acc);color:#fff;}
.act-del{color:#666;border-color:#1e1e1e;background:#111;}
.act-del:hover{background:#e53935;color:#fff;border-color:#e53935;}

/* CHAT MONITOR */
.cm-grid{display:grid;grid-template-columns:260px 1fr;height:460px;}
.cm-list{border-right:1px solid var(--border);overflow-y:auto;}
.cm-ci{padding:11px 14px;cursor:pointer;border-bottom:1px solid #111;transition:background .15s;}
.cm-ci:hover,.cm-ci.on{background:#1e1e1e;}
.cm-nm{font-size:12px;font-weight:600;margin-bottom:2px;}
.cm-lm{font-size:11px;color:#333;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cm-msgs-wrap{display:flex;flex-direction:column;height:460px;overflow:hidden;}
.cm-nosel{flex:1;display:flex;align-items:center;justify-content:center;color:#222;font-size:13px;}
.cm-msgs{flex:1;overflow-y:auto;padding:12px 16px;display:flex;flex-direction:column;gap:8px;min-height:0;}
.cm-msgs::-webkit-scrollbar{width:3px;}
.cm-msgs::-webkit-scrollbar-thumb{background:#1e1e1e;}
.cm-msg{max-width:78%;}
.cm-snm{font-size:10px;color:#333;margin-bottom:2px;font-weight:600;}
.cm-bbl{background:#1e1e1e;border:1px solid #252525;border-radius:8px;padding:7px 11px;font-size:12px;line-height:1.55;}
.cm-t{font-size:10px;color:#222;margin-top:2px;}

/* TOAST */
.toast{position:fixed;bottom:20px;right:20px;background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;padding:10px 16px;font-size:13px;font-weight:600;z-index:9999;transform:translateY(60px);opacity:0;transition:all .25s;max-width:280px;}
.toast.on{transform:translateY(0);opacity:1;}

/* LOGIN */
#loginScreen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px;width:100vw;position:fixed;inset:0;}
.login-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:32px 28px;width:100%;max-width:360px;}
.login-icon{width:52px;height:52px;border-radius:12px;background:rgba(245,166,35,.1);color:#f5a623;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:18px;}
.login-title{font-size:20px;font-weight:800;margin-bottom:6px;}
.login-sub{font-size:13px;color:#444;margin-bottom:22px;}
.l-inp{width:100%;background:#0d0d0d;border:1px solid var(--border);border-radius:9px;padding:10px 13px;color:var(--text);font-size:13px;outline:none;margin-bottom:10px;font-family:'Inter',sans-serif;transition:border-color .2s;}
.l-inp:focus{border-color:#f5a623;}
.l-err{font-size:12px;color:var(--acc);margin-bottom:10px;display:none;}
.l-err.on{display:block;}
.l-btn{width:100%;padding:11px;background:#f5a623;border:none;border-radius:9px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s;}
.l-btn:hover{background:#e09400;}

@media(max-width:768px){
  .sidebar{display:none;}
  .content{padding:14px;}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-icon"><i class="fa fa-user-shield"></i></div>
    <div class="login-title"><em>Game</em>Off <span class="sb-moder-badge">MODER</span></div>
    <div class="login-sub">Панель модератора платформы</div>
