<script src="https://www.gstatic.com/firebasejs/11.4.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/11.4.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/11.4.0/firebase-firestore-compat.js"></script>
<script>
const FC={apiKey:"AIzaSyDXkTBDdRFx2Fjeqk0ji4cN5-dbYajyBvE",authDomain:"gameoff-9c1ab.firebaseapp.com",projectId:"gameoff-9c1ab",storageBucket:"gameoff-9c1ab.firebasestorage.app",messagingSenderId:"826520882064",appId:"1:826520882064:web:b5131597db8a59993cc115",measurementId:"G-ZXNZ8DJWMP"};
firebase.initializeApp(FC);
const auth=firebase.auth();

const PROJECT='gameoff-9c1ab';
const FSBASE=`https://firestore.googleapis.com/v1/projects/${PROJECT}/databases/default/documents`;
let _idToken=null;
let allListings=[],allChats=[],chatMsgUnsub=null;

const TL={skin:'Скин',acc:'Аккаунт',cur:'Валюта',item:'Предмет'};
const SL={pending:'На проверке',approved:'Опубликован',rejected:'Отклонён'};
const SC={pending:'b-yellow',approved:'b-green',rejected:'b-red'};

function esc(t){return(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function fmtT(ts){if(!ts)return'';try{const d=ts.toDate?ts.toDate():ts.seconds?new Date(ts.seconds*1000):new Date(ts);return d.toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});}catch{return'';}}
let _tt;
function tst(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('on');clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('on'),3000);}

// ===== REST API =====
function fsDoc2obj(doc){if(!doc||!doc.fields)return null;const obj={};for(const[k,v]of Object.entries(doc.fields)){if(v.stringValue!==undefined)obj[k]=v.stringValue;else if(v.integerValue!==undefined)obj[k]=Number(v.integerValue);else if(v.doubleValue!==undefined)obj[k]=v.doubleValue;else if(v.booleanValue!==undefined)obj[k]=v.booleanValue;else if(v.nullValue!==undefined)obj[k]=null;else if(v.timestampValue!==undefined)obj[k]={toDate:()=>new Date(v.timestampValue),seconds:Math.floor(new Date(v.timestampValue).getTime()/1000)};else if(v.arrayValue)obj[k]=(v.arrayValue.values||[]).map(x=>fsDoc2obj({fields:{_:x}})._);else if(v.mapValue)obj[k]=fsDoc2obj(v.mapValue);}return obj;}
function obj2fs(obj){const fields={};for(const[k,v]of Object.entries(obj)){if(v===null||v===undefined)fields[k]={nullValue:null};else if(typeof v==='boolean')fields[k]={booleanValue:v};else if(typeof v==='number')fields[k]=Number.isInteger(v)?{integerValue:String(v)}:{doubleValue:v};else if(typeof v==='string')fields[k]={stringValue:v};else if(v&&typeof v==='object'&&v.serverTimestamp)fields[k]={timestampValue:new Date().toISOString()};else if(Array.isArray(v))fields[k]={arrayValue:{values:v.map(x=>obj2fs({_:x}).fields._)}};else if(v&&typeof v==='object')fields[k]={mapValue:{fields:obj2fs(v).fields}};}return{fields};}
async function getToken(){if(_idToken)return _idToken;try{const u=firebase.auth().currentUser;if(u){_idToken=await u.getIdToken();return _idToken;}}catch(e){}return null;}
async function restGet(col,id){const token=await getToken();const h={'Content-Type':'application/json'};if(token)h['Authorization']='Bearer '+token;const r=await fetch(`${FSBASE}/${col}/${id}`,{headers:h});if(r.status===404)return{exists:false,data:()=>null,id};if(!r.ok)throw new Error('GET '+r.status);const doc=await r.json();return{exists:true,data:()=>fsDoc2obj(doc),id:doc.name?.split('/').pop()||id};}
async function restSet(col,id,data){const token=await getToken();const h={'Content-Type':'application/json'};if(token)h['Authorization']='Bearer '+token;const keys=Object.keys(data).join('&updateMask.fieldPaths=');const r=await fetch(`${FSBASE}/${col}/${id}?updateMask.fieldPaths=${keys}`,{method:'PATCH',headers:h,body:JSON.stringify(obj2fs(data))});if(!r.ok){const e=await r.json();throw new Error(e.error?.message||r.status);}return{id};}
async function restQuery(col,filters=[],order=null){const token=await getToken();const h={'Content-Type':'application/json'};if(token)h['Authorization']='Bearer '+token;const sq={from:[{collectionId:col.split('/').pop()}]};if(col.includes('/')){const parts=col.split('/');sq.from=[{collectionId:parts[parts.length-1]}];}if(filters.length===1){const[field,op,val]=filters[0];const om={'==':'EQUAL','array-contains':'ARRAY_CONTAINS'};sq.where={fieldFilter:{field:{fieldPath:field},op:om[op]||'EQUAL',value:obj2fs({v:val}).fields.v}};}else if(filters.length>1){sq.where={compositeFilter:{op:'AND',filters:filters.map(([field,op,val])=>{const om={'==':'EQUAL','array-contains':'ARRAY_CONTAINS'};return{fieldFilter:{field:{fieldPath:field},op:om[op]||'EQUAL',value:obj2fs({v:val}).fields.v}};})}};}if(order)sq.orderBy=[{field:{fieldPath:order.field},direction:order.dir||'ASCENDING'}];let url=`${FSBASE}:runQuery`;if(col.includes('/')){const parts=col.split('/');url=`${FSBASE}/${parts.slice(0,-1).join('/')}:runQuery`;}const r=await fetch(url,{method:'POST',headers:h,body:JSON.stringify({structuredQuery:sq})});if(!r.ok)throw new Error('QUERY '+r.status);const res=await r.json();return(res||[]).filter(x=>x.document).map(x=>({id:x.document.name?.split('/').pop(),...fsDoc2obj(x.document),data:()=>fsDoc2obj(x.document)}));}
function restOnCollectionSnapshot(col,filters,order,callback){let last=null;async function poll(){try{const docs=await restQuery(col,filters||[],order);const curr=JSON.stringify(docs.map(d=>d.id+JSON.stringify(d)));if(curr!==last){last=curr;callback({docs:docs.map(d=>({id:d.id,data:()=>d,exists:true}))});}}catch(e){console.warn('poll:',e);}}poll();const t=setInterval(poll,4000);return()=>clearInterval(t);}

// ===== LOGIN =====
window.moderLogin=async()=>{
  const e=document.getElementById('adE').value.trim();
  const p=document.getElementById('adP').value;
  const err=document.getElementById('adErr');
  err.classList.remove('on');
  if(!e||!p){err.textContent='Введи email и пароль';err.classList.add('on');return;}
  const btn=document.querySelector('.l-btn');
  btn.disabled=true;btn.innerHTML='<i class="fa fa-spinner fa-spin" style="margin-right:6px"></i>Входим...';
  try{
    const apiKey='AIzaSyDXkTBDdRFx2Fjeqk0ji4cN5-dbYajyBvE';
    const resp=await fetch(`https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`,{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({email:e,password:p,returnSecureToken:true})
    });
    const data=await resp.json();
    if(!resp.ok)throw{code:data.error?.message,message:data.error?.message||'Ошибка входа'};
    // Проверяем роль в Firestore
    _idToken=data.idToken;
    const uid=data.localId;
    const userSnap=await restGet('users',uid);
    if(!userSnap.exists)throw{code:'NO_ROLE',message:'Нет доступа к панели модератора'};
    const role=userSnap.data()?.role;
    if(role!=='moder'&&role!=='admin')throw{code:'NO_ROLE',message:'Нет доступа. Обратитесь к администратору'};
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('moderApp').style.display='flex';
    document.getElementById('adEmail').textContent=data.email;
    loadAll();
  }catch(ex){
    _idToken=null;
    const m={'EMAIL_NOT_FOUND':'Пользователь не найден','INVALID_PASSWORD':'Неверный пароль','INVALID_LOGIN_CREDENTIALS':'Неверный email или пароль','NO_ROLE':'Нет доступа к панели модератора'};
    err.textContent=m[ex.code]||(ex.message||'Ошибка входа');
    err.classList.add('on');
  }finally{
    btn.disabled=false;btn.innerHTML='<i class="fa fa-sign-in-alt" style="margin-right:6px"></i>Войти';
  }
};

window.doLogout=()=>{_idToken=null;document.getElementById('moderApp').style.display='none';document.getElementById('loginScreen').style.display='flex';};

// ===== TABS =====
window.showTab=function(name,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('on'));
  document.getElementById('tab-'+name).classList.add('on');
  el.classList.add('on');
  const titles={mod:'Модерация',listings:'Объявления',chats:'Чаты'};
  const icons={mod:'fa-check-circle',listings:'fa-tag',chats:'fa-comments'};
  document.getElementById('pageTitle').innerHTML=`<i class="fa ${icons[name]}" style="color:var(--acc)"></i> ${titles[name]}`;
};

// ===== LOAD =====
function loadAll(){
  restOnCollectionSnapshot('listings',[['status','==','pending']],null,snap=>{
    const items=snap.docs.map(d=>({id:d.id,...d.data()}));
    renderMod(items);
    document.getElementById('modBadge').textContent=items.length||'';
  });
  restOnCollectionSnapshot('listings',[],null,snap=>{
    allListings=snap.docs.map(d=>({id:d.id,...d.data()}));
    renderListings(allListings);
  });
  restOnCollectionSnapshot('conversations',[],{field:'lastTime',dir:'DESCENDING'},snap=>{
    allChats=snap.docs.map(d=>({id:d.id,...d.data()}));
    renderCmList(allChats);
  });
}

// ===== RENDER MOD =====
function renderMod(items){
  const tb=document.getElementById('modTable');
  if(!items.length){tb.innerHTML='<tr class="empty-row"><td colspan="7">Нет объявлений на проверке</td></tr>';return;}
  tb.innerHTML=items.map(l=>`<tr>
    <td><strong>${esc(l.n||'—')}</strong></td>
    <td style="color:#555">${esc(l.g||'—')}</td>
    <td><span class="badge b-gray">${TL[l.t]||'—'}</span></td>
    <td style="color:#f5a623;font-weight:700">${(l.p||0).toLocaleString('ru')} руб.</td>
    <td>${esc(l.s||'—')}</td>
    <td style="color:#444;font-size:11px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(l.desc||'—')}</td>
    <td><div class="acts">
      <button class="act act-ok" onclick="approve('${l.id}')"><i class="fa fa-check"></i> Одобрить</button>
      <button class="act act-no" onclick="reject('${l.id}')"><i class="fa fa-times"></i> Отклонить</button>
    </div></td>
  </tr>`).join('');
}

// ===== RENDER LISTINGS =====
function renderListings(items){
  const tb=document.getElementById('listingsTable');
  if(!items.length){tb.innerHTML='<tr class="empty-row"><td colspan="6">Нет объявлений</td></tr>';return;}
  tb.innerHTML=items.map(l=>`<tr>
    <td><strong>${esc(l.n||'—')}</strong></td>
    <td style="color:#555">${esc(l.g||'—')}</td>
    <td style="color:#f5a623;font-weight:700">${(l.p||0).toLocaleString('ru')} руб.</td>
    <td>${esc(l.s||'—')}</td>
    <td><span class="badge ${SC[l.status]||'b-gray'}">${SL[l.status]||'—'}</span></td>
    <td><div class="acts">
      ${l.status==='pending'?`<button class="act act-ok" onclick="approve('${l.id}')"><i class="fa fa-check"></i></button><button class="act act-no" onclick="reject('${l.id}')"><i class="fa fa-times"></i></button>`:''}
      <button class="act act-del" onclick="delListing('${l.id}')"><i class="fa fa-trash"></i></button>
    </div></td>
  </tr>`).join('');
}

// ===== RENDER CHATS =====
function renderCmList(chats){
  const el=document.getElementById('cmList');
  if(!chats.length){el.innerHTML='<div style="padding:20px;text-align:center;color:#222;font-size:12px">Нет чатов</div>';return;}
  el.innerHTML=[...chats].sort((a,b)=>(b.lastTime?.seconds||0)-(a.lastTime?.seconds||0)).map(c=>`
    <div class="cm-ci" id="cmc-${c.id}" onclick="viewChat('${c.id}',this)">
      <div class="cm-nm">${Object.values(c.participantNames||{}).join(' ↔ ')||'—'}</div>
      <div class="cm-lm">${esc(c.lastMsg||c.itemName||'—')}</div>
    </div>`).join('');
}

window.viewChat=function(id,el){
  document.querySelectorAll('.cm-ci').forEach(x=>x.classList.remove('on'));el.classList.add('on');
  document.getElementById('cmNoSel').style.display='none';
  const msgs=document.getElementById('cmMsgs');msgs.style.display='flex';msgs.innerHTML='';
  if(chatMsgUnsub)chatMsgUnsub();
  chatMsgUnsub=restOnCollectionSnapshot('conversations/'+id+'/messages',[],{field:'ts',dir:'ASCENDING'},snap=>{
    const docs=snap.docs||[];
    msgs.innerHTML='';
    if(!docs.length){msgs.innerHTML='<div style="padding:20px;color:#555;text-align:center;font-size:12px">Нет сообщений</div>';return;}
    docs.forEach(d=>{
      const m=d.data();let t='';
      try{const ts=m.ts;if(ts?.toDate)t=ts.toDate().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});else if(ts?.seconds)t=new Date(ts.seconds*1000).toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});}catch{}
      msgs.innerHTML+=`<div class="cm-msg"><div class="cm-snm">${esc(m.senderName||'?')}</div><div class="cm-bbl">${esc(m.text||'')}</div><div class="cm-t">${t}</div></div>`;
    });
    msgs.scrollTop=msgs.scrollHeight;
  });
};

// ===== ACTIONS =====
window.approve=async id=>{await restSet('listings',id,{status:'approved'});tst('Объявление опубликовано');};
window.reject=async id=>{if(!confirm('Отклонить?'))return;await restSet('listings',id,{status:'rejected'});tst('Объявление отклонено');};
window.delListing=async id=>{
  if(!confirm('Удалить объявление?'))return;
  const token=await getToken();
  await fetch(`${FSBASE}/listings/${id}`,{method:'DELETE',headers:{Authorization:'Bearer '+token}});
  tst('Удалено');
};
window.filterListings=q=>{renderListings(q?allListings.filter(l=>(l.n||'').toLowerCase().includes(q.toLowerCase())):allListings);};
</script>
